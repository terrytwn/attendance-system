/* ---------------- 打卡定位檢查 ---------------- */
function getPosition(){
  return new Promise((resolve, reject)=>{
    if (!navigator.geolocation){ reject(new Error('此瀏覽器不支援定位功能')); return; }
    navigator.geolocation.getCurrentPosition(
      pos => resolve(pos.coords),
      err => reject(new Error(
        err.code === 1 ? '請允許瀏覽器存取你的位置,才能打卡' : '無法取得目前位置,請確認定位已開啟'
      )),
      { enableHighAccuracy:true, timeout:10000 }
    );
  });
}
function distanceMeters(lat1, lng1, lat2, lng2){
  const R = 6371000;
  const toRad = d => d * Math.PI / 180;
  const dLat = toRad(lat2-lat1), dLng = toRad(lng2-lng1);
  const a = Math.sin(dLat/2)**2 + Math.cos(toRad(lat1))*Math.cos(toRad(lat2))*Math.sin(dLng/2)**2;
  return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
}
async function checkAtOffice(){
  const coords = await getPosition();
  const dist = distanceMeters(coords.latitude, coords.longitude, OFFICE_LAT, OFFICE_LNG);
  if (dist > OFFICE_RADIUS_M){
    const err = new Error(`目前位置距離公司約 ${Math.round(dist)} 公尺,超出允許範圍(${OFFICE_RADIUS_M} 公尺),無法打卡`);
    err.coords = coords;
    throw err;
  }
  return coords;
}

