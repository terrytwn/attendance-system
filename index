async function loadScheduleForDate(){
  const dateEl = document.getElementById('scheduleDate');
  const container = document.getElementById('scheduleByDept');
  if (!dateEl || !dateEl.value){ if(container) container.innerHTML=''; return; }
  const dateStr = dateEl.value;
  const weekday = new Date(dateStr + 'T00:00:00').getDay();

  const { data: emps } = await sb.from('employees').select('*, departments(id,name)').order('name');
  const { data: sched } = await sb.from('schedules').select('*').eq('work_date', dateStr);
  const schedMap = {};
  (sched||[]).forEach(s => schedMap[s.employee_id] = s.shift_status);
  const { data: rules } = await sb.from('department_staffing_rules').select('*').eq('weekday', weekday);
  const ruleMap = {};
  (rules||[]).forEach(r => ruleMap[r.department_id] = r.min_headcount);

  const groups = {};
  (emps||[]).forEach(e=>{
    const key = e.department_id || 'none';
    const name = e.departments?.name || '未分類';
    if (!groups[key]) groups[key] = { name, employees: [] };
    groups[key].employees.push(e);
  });

  container.innerHTML = Object.entries(groups).map(([deptId, g])=>{
    const scheduledCount = g.employees.filter(e => (schedMap[e.id] || '上班') === '上班').length;
    const min = ruleMap[deptId];
    const badge = (min !== undefined)
      ? `<span class="badge ${scheduledCount < min ? 'badge-bad' : 'badge-ok'}">已排 ${scheduledCount} 人 / 最低 ${min} 人${scheduledCount < min ? '(人力不足)' : ''}</span>`
      : `<span class="badge badge-pending">已排 ${scheduledCount} 人</span>`;
    const chips = g.employees.map(e=>{
      const on = (schedMap[e.id] || '上班') === '上班';
      return `<label style="display:flex; align-items:center; gap:6px; font-size:13px; background:var(--paper); border:1px solid var(--line); border-radius:20px; padding:6px 12px;">
        <input type="checkbox" ${on?'checked':''} onchange="toggleShift('${e.id}','${dateStr}',this.checked)"> ${e.name}
      </label>`;
    }).join('');
    return `<div style="margin-bottom:18px; padding-bottom:14px; border-bottom:1px solid var(--line);">
      <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; flex-wrap:wrap; gap:8px;">
        <strong>${g.name}</strong>${badge}
      </div>
      <div style="display:flex; flex-wrap:wrap; gap:10px;">${chips || '<span class="empty">此部門尚無員工</span>'}</div>
    </div>`;
  }).join('') || '<div class="empty">尚無員工資料</div>';
}
async function toggleShift(employeeId, dateStr, isChecked){
  await sb.from('schedules').upsert(
    { employee_id: employeeId, work_date: dateStr, shift_status: isChecked ? '上班' : '休假', source: 'admin' },
    { onConflict: 'employee_id,work_date' }
  );
  loadScheduleForDate();
}

/* ---------------- 報表 ---------------- */
let reportAttCache = [], reportOtCache = [];
async function generateReports(){
  const start = document.getElementById('repStart').value;
  const end = document.getElementById('repEnd').value;
  if (!start || !end) return;

  const { data: att } = await sb.from('attendance').select('*, employees(name)')
    .gte('work_date', start).lte('work_date', end).order('work_date');
  reportAttCache = att || [];
  document.getElementById('repAttBody').innerHTML = reportAttCache.map(r=>
    `<tr><td>${r.employees?.name||'-'}</td><td>${r.work_date}</td><td>${r.check_in||'-'}</td><td>${r.check_out||'-'}</td><td>${statusBadge(r.status)}</td></tr>`
  ).join('');
  document.getElementById('repAttEmpty').classList.toggle('hidden', reportAttCache.length>0);

  const { data: ot } = await sb.from('overtime_requests').select('*, employees(name)')
    .eq('status','approved').gte('work_date', start).lte('work_date', end);
  const sums = {};
  (ot||[]).forEach(r=>{
    const name = r.employees?.name || '-';
    sums[name] = (sums[name]||0) + Number(r.hours);
  });
  reportOtCache = Object.entries(sums).map(([name,hours])=>({name,hours}));
  document.getElementById('repOtBody').innerHTML = reportOtCache.map(r=>`<tr><td>${r.name}</td><td>${r.hours}</td></tr>`).join('');
  document.getElementById('repOtEmpty').classList.toggle('hidden', reportOtCache.length>0);
}
function toCSV(rows){
  return '\uFEFF' + rows.map(row=>row.map(v=>`"${String(v??'').replace(/"/g,'""')}"`).join(',')).join('\r\n');
}
function downloadCSV(filename, csvContent){
  const blob = new Blob([csvContent], {type:'text/csv;charset=utf-8;'});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  URL.revokeObjectURL(url);
}
function exportAttendanceCSV(){
  const rows = [['姓名','日期','上班','下班','狀態']].concat(
    reportAttCache.map(r=>[r.employees?.name||'-', r.work_date, r.check_in||'', r.check_out||'', r.status])
  );
  downloadCSV('出勤紀錄.csv', toCSV(rows));
}
function exportOvertimeCSV(){
  const rows = [['姓名','已核准加班時數合計']].concat(reportOtCache.map(r=>[r.name, r.hours]));
  downloadCSV('加班統計.csv', toCSV(rows));
}

