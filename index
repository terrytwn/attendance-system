<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>差勤管理系統</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@500;700&family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
  :root{
    --navy:#1B2A4A;
    --navy-light:#2C4270;
    --paper:#F7F8FA;
    --paper-card:#FFFFFF;
    --gold:#C9A227;
    --ink:#22252B;
    --muted:#6B7280;
    --line:#E3E6EC;
    --danger:#B4443B;
    --ok:#2F6F4E;
    --radius:6px;
  }
  *{box-sizing:border-box;}
  body{
    margin:0; background:var(--paper); color:var(--ink);
    font-family:'Noto Sans TC',sans-serif; min-height:100vh;
  }
  h1,h2,h3{ font-family:'Noto Serif TC',serif; font-weight:700; margin:0 0 4px; }
  .hidden{display:none !important;}

  /* ---------- 登入畫面 ---------- */
  #loginScreen{
    min-height:100vh; display:flex; align-items:center; justify-content:center;
    background:linear-gradient(160deg, var(--navy) 0%, var(--navy-light) 100%);
  }
  .login-card{
    background:var(--paper-card); width:360px; padding:40px 32px;
    border-radius:var(--radius); box-shadow:0 20px 60px rgba(0,0,0,.35);
    border-top:4px solid var(--gold);
  }
  .login-card .eyebrow{ letter-spacing:.15em; font-size:11px; color:var(--gold); font-weight:700; }
  .login-card h1{ font-size:22px; color:var(--navy); margin-bottom:20px; }
  label{ display:block; font-size:13px; color:var(--muted); margin:14px 0 6px; }
  input, select{
    width:100%; padding:10px 12px; border:1px solid var(--line); border-radius:4px;
    font-family:inherit; font-size:14px; background:#fff;
  }
  input:focus, select:focus{ outline:2px solid var(--navy-light); outline-offset:1px; }
  button{
    cursor:pointer; font-family:inherit; border:none; border-radius:4px;
    font-weight:700; font-size:14px; padding:10px 16px;
  }
  button:disabled{ opacity:.45; cursor:not-allowed; }
  .btn-primary{ background:var(--navy); color:#fff; width:100%; margin-top:20px; }
  .btn-primary:hover{ background:var(--navy-light); }
  .btn-gold{ background:var(--gold); color:var(--navy); }
  .btn-outline{ background:#fff; border:1px solid var(--line) !important; color:var(--ink); }
  .btn-danger{ background:var(--danger); color:#fff; }
  #loginError{ color:var(--danger); font-size:13px; margin-top:10px; min-height:16px; }

  /* ---------- 主應用 ---------- */
  #appScreen{ display:none; }
  header.topbar{
    background:var(--navy); color:#fff; padding:16px 28px;
    display:flex; align-items:center; justify-content:space-between;
  }
  header.topbar .brand{ font-family:'Noto Serif TC',serif; font-size:18px; }
  header.topbar .brand .eyebrow{ display:block; font-size:10px; letter-spacing:.2em; color:var(--gold); font-weight:700; }
  header.topbar .who{ font-size:13px; opacity:.85; display:flex; align-items:center; gap:14px; }

  nav.tabs{
    display:flex; gap:2px; background:#fff; border-bottom:1px solid var(--line);
    padding:0 28px; overflow-x:auto;
  }
  nav.tabs button{
    background:transparent; color:var(--muted); padding:14px 16px; border-radius:0;
    border-bottom:3px solid transparent; font-weight:500; white-space:nowrap;
  }
  nav.tabs button.active{ color:var(--navy); border-bottom-color:var(--gold); font-weight:700; }

  main{ padding:28px; max-width:1100px; margin:0 auto; }
  .card{
    background:var(--paper-card); border:1px solid var(--line); border-radius:var(--radius);
    padding:22px; margin-bottom:20px;
  }
  .card h2{ font-size:16px; color:var(--navy); }
  .grid3{ display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
  .stat{
    background:var(--paper); border:1px solid var(--line); border-radius:var(--radius);
    padding:16px; text-align:center;
  }
  .stat .num{ font-family:'Noto Serif TC',serif; font-size:30px; color:var(--navy); font-weight:700; }
  .stat .label{ font-size:12px; color:var(--muted); margin-top:4px; }

  table{ width:100%; border-collapse:collapse; font-size:13.5px; }
  th, td{ text-align:left; padding:9px 10px; border-bottom:1px solid var(--line); }
  th{ color:var(--muted); font-weight:700; font-size:12px; text-transform:uppercase; letter-spacing:.03em; }
  tr:hover td{ background:#FAFBFD; }
  .badge{ padding:2px 9px; border-radius:20px; font-size:12px; font-weight:700; display:inline-block; }
  .badge-ok{ background:#E7F3EC; color:var(--ok); }
  .badge-pending{ background:#FDF3DC; color:#8A6A16; }
  .badge-bad{ background:#FBEAE8; color:var(--danger); }

  .form-row{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
  .actions{ margin-top:16px; display:flex; gap:10px; }
  .msg{ font-size:13px; margin-top:10px; }
  .msg.ok{ color:var(--ok); } .msg.bad{ color:var(--danger); }
  .empty{ color:var(--muted); font-size:13px; padding:14px 0; }
  .hint{ font-size:12px; color:var(--muted); margin-top:-6px; }
  @media (max-width:640px){ .grid3,.form-row{ grid-template-columns:1fr; } main{padding:16px;} header.topbar{padding:14px 16px;} nav.tabs{padding:0 16px;} }
</style>
</head>
<body>

<!-- ============ 登入畫面 ============ -->
<div id="loginScreen">
  <div class="login-card">
    <span class="eyebrow">差勤管理系統</span>
    <h1>請登入</h1>
    <label for="loginEmpNo">員工編號</label>
    <input id="loginEmpNo" type="text" placeholder="例如 A0123">
    <label for="loginPw">密碼</label>
    <input id="loginPw" type="password" placeholder="••••••••">
    <button class="btn-primary" onclick="doLogin()">登入</button>
    <div id="loginError"></div>
    <div style="margin-top:18px; font-size:12px; color:var(--muted);">
      尚未有帳號?請聯絡管理者為你建立。
    </div>
  </div>
</div>

<!-- ============ 主應用畫面 ============ -->
<div id="appScreen">
  <header class="topbar">
    <div class="brand"><span class="eyebrow">ATTENDANCE SYSTEM</span>差勤管理系統</div>
    <div class="who">
      <span id="whoName"></span>
      <button class="btn-outline" onclick="doLogout()">登出</button>
    </div>
  </header>

  <nav class="tabs" id="tabsNav">
    <button data-tab="dashboard" class="active" onclick="switchTab('dashboard')">儀表板</button>
    <button data-tab="checkin" onclick="switchTab('checkin')">打卡</button>
    <button data-tab="leave" onclick="switchTab('leave')">請假申請</button>
    <button data-tab="dayoff" onclick="switchTab('dayoff')">排休</button>
    <button data-tab="overtime" onclick="switchTab('overtime')">加班申請</button>
    <button data-tab="admin" onclick="switchTab('admin')" id="tabAdminBtn" class="hidden">員工與審核管理</button>
    <button data-tab="schedule" onclick="switchTab('schedule')" id="tabScheduleBtn" class="hidden">排班管理</button>
    <button data-tab="reports" onclick="switchTab('reports')" id="tabReportsBtn" class="hidden">報表</button>
  </nav>

  <main>
    <!-- 儀表板 -->
    <section id="tab-dashboard">
      <div class="card">
        <h2>我的特休狀況</h2>
        <div class="grid3" id="leaveStats" style="margin-top:14px;"></div>
      </div>
      <div class="card">
        <h2>本月出勤記錄</h2>
        <table id="attTable"><thead><tr><th>日期</th><th>上班</th><th>下班</th><th>狀態</th><th>備註</th></tr></thead>
        <tbody id="attTableBody"></tbody></table>
        <div class="empty hidden" id="attEmpty">尚無本月出勤記錄。</div>
      </div>
    </section>

    <!-- 打卡 -->
    <section id="tab-checkin" class="hidden">
      <div class="card">
        <h2>今日打卡</h2>
        <p style="color:var(--muted); font-size:13px;" id="todayLabel"></p>
        <p class="hint">打卡時系統會請求你的位置權限,僅在公司範圍內(半徑 150 公尺)才能成功打卡,請於彈出視窗選擇「允許」。</p>
        <div class="actions">
          <button class="btn-gold" onclick="clockIn()">上班打卡</button>
          <button class="btn-outline" onclick="clockOut()">下班打卡</button>
        </div>
        <div class="msg" id="clockMsg"></div>
      </div>
    </section>

    <!-- 請假申請(須主管審核) -->
    <section id="tab-leave" class="hidden">
      <div class="card">
        <h2>提出請假申請</h2>
        <p class="hint">特休、事假、病假、公假等,送出後需等待主管核准才會生效。</p>
        <div class="form-row">
          <div>
            <label>假別</label>
            <select id="leaveType">
              <option value="特休">特休</option>
              <option value="事假">事假</option>
              <option value="病假">病假</option>
              <option value="公假">公假</option>
              <option value="其他">其他</option>
            </select>
          </div>
          <div>
            <label>天數</label>
            <input id="leaveDays" type="number" min="0.5" step="0.5" placeholder="例如 1">
          </div>
          <div>
            <label>起始日期</label>
            <input id="leaveStart" type="date">
          </div>
          <div>
            <label>結束日期</label>
            <input id="leaveEnd" type="date">
          </div>
        </div>
        <label>事由(選填)</label>
        <input id="leaveReason" type="text" placeholder="簡述請假原因">
        <div class="actions"><button class="btn-primary" style="width:auto;" onclick="submitLeave()">送出申請</button></div>
        <div class="msg" id="leaveMsg"></div>
      </div>
      <div class="card">
        <h2>我的請假紀錄</h2>
        <table><thead><tr><th>假別</th><th>期間</th><th>天數</th><th>狀態</th></tr></thead>
        <tbody id="myLeaveBody"></tbody></table>
        <div class="empty hidden" id="myLeaveEmpty">尚無請假紀錄。</div>
      </div>
    </section>

    <!-- 排休(自行安排,免審核) -->
    <section id="tab-dayoff" class="hidden">
      <div class="card">
        <h2>排休申請</h2>
        <p class="hint">原則上每週 6 個上班日(週一至週六)可以自行挑一天休息,不需要主管審核,送出後立即生效。</p>
        <div class="form-row">
          <div>
            <label>選擇週別</label>
            <select id="dayoffWeekSel" onchange="onDayoffWeekChange()">
              <option value="0">本週</option>
              <option value="1">下週</option>
            </select>
          </div>
          <div>
            <label>選擇要排休的日子</label>
            <select id="dayoffDateSel"></select>
          </div>
        </div>
        <p id="dayoffCurrentInfo" style="font-size:13px; color:var(--muted); margin-top:6px;"></p>
        <div class="actions"><button class="btn-primary" id="dayoffApplyBtn" style="width:auto;" onclick="applyDayoff()">送出排休</button></div>
        <div class="msg" id="dayoffMsg"></div>
      </div>
    </section>

    <!-- 加班申請(須主管審核) -->
    <section id="tab-overtime" class="hidden">
      <div class="card">
        <h2>加班申請</h2>
        <div class="form-row">
          <div><label>加班日期</label><input id="otDate" type="date"></div>
          <div><label>加班時數</label><input id="otHours" type="number" min="0.5" step="0.5" placeholder="例如 2"></div>
        </div>
        <label>事由(選填)</label>
        <input id="otReason" type="text" placeholder="簡述加班原因">
        <div class="actions"><button class="btn-primary" style="width:auto;" onclick="submitOvertime()">送出申請</button></div>
        <div class="msg" id="otMsg"></div>
      </div>
      <div class="card">
        <h2>我的加班紀錄</h2>
        <table><thead><tr><th>日期</th><th>時數</th><th>狀態</th></tr></thead>
        <tbody id="myOvertimeBody"></tbody></table>
        <div class="empty hidden" id="myOvertimeEmpty">尚無加班紀錄。</div>
      </div>
    </section>

    <!-- 管理(admin only) -->
    <section id="tab-admin" class="hidden">
      <div class="card">
        <h2>新增員工</h2>
        <div class="form-row">
          <div><label>員工編號(登入用,須唯一)</label><input id="newEmpNo" type="text" placeholder="例如 A0123"></div>
          <div><label>姓名</label><input id="newEmpName" type="text"></div>
          <div><label>Email(選填,僅供聯絡)</label><input id="newEmpEmail" type="email"></div>
          <div><label>到職日</label><input id="newEmpHire" type="date"></div>
          <div><label>部門</label><select id="newEmpDept"><option value="">未分類</option></select></div>
          <div><label>角色</label>
            <select id="newEmpRole"><option value="employee">一般員工</option><option value="admin">主管/管理者</option></select>
          </div>
        </div>
        <div class="actions"><button class="btn-primary" style="width:auto;" onclick="addEmployee()">新增</button></div>
        <div class="msg" id="empMsg"></div>
        <p class="hint">註:新增此列後,還要到 Supabase 後台 Authentication → Add user,用「員工編號@attendance.local」當 Email 幫該員工建立密碼,他才能實際登入。</p>
      </div>

      <div class="card">
        <h2>員工特休總覽</h2>
        <table><thead><tr><th>員工編號</th><th>姓名</th><th>部門</th><th>到職日</th><th>年資</th><th>特休總天數</th><th>已休</th><th>剩餘</th></tr></thead>
        <tbody id="empOverviewBody"></tbody></table>
      </div>

      <div class="card">
        <h2>請假審核</h2>
        <table><thead><tr><th>姓名</th><th>假別</th><th>期間</th><th>天數</th><th>狀態</th><th>操作</th></tr></thead>
        <tbody id="pendingLeaveBody"></tbody></table>
        <div class="empty hidden" id="pendingLeaveEmpty">目前沒有待審核的請假申請。</div>
      </div>

      <div class="card">
        <h2>加班審核</h2>
        <table><thead><tr><th>姓名</th><th>日期</th><th>時數</th><th>事由</th><th>狀態</th><th>操作</th></tr></thead>
        <tbody id="pendingOvertimeBody"></tbody></table>
        <div class="empty hidden" id="pendingOvertimeEmpty">目前沒有待審核的加班申請。</div>
      </div>
    </section>

    <!-- 排班管理(admin only) -->
    <section id="tab-schedule" class="hidden">
      <div class="card">
        <h2>部門管理</h2>
        <div class="form-row">
          <div><label>新增部門名稱</label><input id="newDeptName" type="text" placeholder="例如 業務部"></div>
        </div>
        <div class="actions"><button class="btn-primary" style="width:auto;" onclick="addDepartment()">新增部門</button></div>
        <div class="msg" id="deptMsg"></div>
        <table style="margin-top:14px;"><thead><tr><th>部門名稱</th></tr></thead><tbody id="deptListBody"></tbody></table>
      </div>

      <div class="card">
        <h2>最低到班人數設定</h2>
        <p class="hint">設定某部門在星期幾至少要有幾人排班上班,下方排班表會依此即時比對、標示不足。</p>
        <div class="form-row">
          <div><label>部門</label><select id="ruleDept"></select></div>
          <div><label>星期</label>
            <select id="ruleWeekday">
              <option value="1">星期一</option>
              <option value="2">星期二</option>
              <option value="3">星期三</option>
              <option value="4">星期四</option>
              <option value="5">星期五</option>
              <option value="6" selected>星期六</option>
              <option value="0">星期日</option>
            </select>
          </div>
          <div><label>最低到班人數</label><input id="ruleMinCount" type="number" min="0" step="1" placeholder="例如 2"></div>
        </div>
        <div class="actions"><button class="btn-primary" style="width:auto;" onclick="saveStaffingRule()">儲存設定</button></div>
        <div class="msg" id="ruleMsg"></div>
        <table style="margin-top:14px;"><thead><tr><th>部門</th><th>星期</th><th>最低人數</th><th>操作</th></tr></thead><tbody id="ruleListBody"></tbody></table>
      </div>

      <div class="card">
        <h2>排班表</h2>
        <div class="form-row" style="grid-template-columns:220px 1fr;">
          <div><label>選擇日期</label><input id="scheduleDate" type="date" onchange="loadScheduleForDate()"></div>
        </div>
        <p class="hint">預設每位員工每天都算「上班」,取消勾選代表當天排休。人數不足最低要求時會以紅色標示。員工自行排休(來自「排休」頁籤)也會顯示在這裡。</p>
        <div id="scheduleByDept" style="margin-top:14px;"></div>
      </div>
    </section>

    <!-- 報表(admin only) -->
    <section id="tab-reports" class="hidden">
      <div class="card">
        <h2>報表區間</h2>
        <div class="form-row">
          <div><label>起始日期</label><input id="repStart" type="date"></div>
          <div><label>結束日期</label><input id="repEnd" type="date"></div>
        </div>
        <div class="actions"><button class="btn-primary" style="width:auto;" onclick="generateReports()">產生報表</button></div>
      </div>

      <div class="card">
        <h2>出勤紀錄</h2>
        <div class="actions" style="margin-top:0;"><button class="btn-outline" onclick="exportAttendanceCSV()">匯出 CSV</button></div>
        <table style="margin-top:10px;"><thead><tr><th>姓名</th><th>日期</th><th>上班</th><th>下班</th><th>狀態</th></tr></thead>
        <tbody id="repAttBody"></tbody></table>
        <div class="empty hidden" id="repAttEmpty">此區間沒有出勤紀錄,請先設定日期並產生報表。</div>
      </div>

      <div class="card">
        <h2>加班統計(已核准)</h2>
        <div class="actions" style="margin-top:0;"><button class="btn-outline" onclick="exportOvertimeCSV()">匯出 CSV</button></div>
        <table style="margin-top:10px;"><thead><tr><th>姓名</th><th>已核准加班時數合計</th></tr></thead>
        <tbody id="repOtBody"></tbody></table>
        <div class="empty hidden" id="repOtEmpty">此區間沒有已核准的加班紀錄。</div>
      </div>
    </section>
  </main>
</div>

<script>
/* ================================================================
   設定區:請在建立好 Supabase 專案後,把下面幾個值換成你自己的
   ================================================================ */
const SUPABASE_URL = "https://falusmyhoasguipyeohr.supabase.co";
const SUPABASE_ANON_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImZhbHVzbXlob2FzZ3VpcHllb2hyIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQwMDg4NTIsImV4cCI6MjA5OTU4NDg1Mn0.jYDGUapHwC5fe-G5x1YgnqDozeu4d20KyxqnNq3NHo8";
const AUTH_EMAIL_DOMAIN = "attendance.local";
const OFFICE_LAT = 24.977405;   // ← 換成你公司的緯度
const OFFICE_LNG = 121.245606;  // ← 換成你公司的經度
const OFFICE_RADIUS_M = 180;

const sb = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

let currentUser = null;
let currentEmp = null;

/* ---------------- 特休計算(勞基法第38條,到職週年制) ---------------- */
function monthsBetween(from, to){
  return (to.getFullYear()-from.getFullYear())*12 + (to.getMonth()-from.getMonth()) -
         (to.getDate() < from.getDate() ? 1 : 0);
}
function calcAnnualLeaveEntitlement(hireDateStr, asOf = new Date()){
  const hire = new Date(hireDateStr + "T00:00:00");
  const months = monthsBetween(hire, asOf);
  if (months < 6) return 0;
  const years = Math.floor(months/12);
  if (years < 1) return 3;
  if (years < 2) return 7;
  if (years < 3) return 10;
  if (years < 5) return 14;
  if (years < 10) return 15;
  return Math.min(15 + (years - 9), 30);
}
function tenureLabel(hireDateStr, asOf = new Date()){
  const hire = new Date(hireDateStr + "T00:00:00");
  const months = monthsBetween(hire, asOf);
  const y = Math.floor(months/12), m = months%12;
  return `${y}年${m}個月`;
}

/* ---------------- 登入 / 登出 ---------------- */
async function doLogin(){
  const empNo = document.getElementById('loginEmpNo').value.trim();
  const password = document.getElementById('loginPw').value;
  const errEl = document.getElementById('loginError');
  errEl.textContent = '';
  if (!empNo){ errEl.textContent = '請輸入員工編號'; return; }
  const email = `${empNo}@${AUTH_EMAIL_DOMAIN}`;
  const { data, error } = await sb.auth.signInWithPassword({ email, password });
  if (error){ errEl.textContent = '登入失敗:員工編號或密碼錯誤'; return; }
  await afterLogin(data.user);
}
async function doLogout(){
  await sb.auth.signOut();
  currentUser = null; currentEmp = null;
  document.getElementById('appScreen').style.display = 'none';
