    infoEl.innerHTML = `這週已排休:<strong>${existing.work_date}</strong>　<button class="btn-outline" style="padding:4px 10px; font-size:12px;" onclick="cancelDayoff('${existing.id}')">取消排休</button>`;
    btnEl.disabled = true;
