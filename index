async function renderDayoffForWeek(offset){
  const monday = mondayOf(new Date());
  monday.setDate(monday.getDate() + offset*7);
  const days = weekDates(monday);
  const labels = ['一','二','三','四','五','六'];
  const sel = document.getElementById('dayoffDateSel');
  sel.innerHTML = days.map((d,i)=>`<option value="${fmtDate(d)}">星期${labels[i]}(${fmtDate(d)})</option>`).join('');

  const startStr = fmtDate(days[0]), endStr = fmtDate(days[5]);
  const { data } = await sb.from('schedules').select('*')
    .eq('employee_id', currentEmp.id).eq('source','self').eq('shift_status','休假')
    .gte('work_date', startStr).lte('work_date', endStr);
  const existing = (data||[])[0];
